generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  club
  reseller
  customer
}

enum PassType {
  night
  weekend
}

enum PassStatus {
  purchased
  active
  expired
  refunded
}

enum TicketStatus {
  purchased
  used
  expired
  refunded
}

enum PricingPhaseName {
  early_bird
  regular
  last_minute
}

enum DayOfWeek {
  friday
  saturday
  sunday
}

enum PassInclusion {
  friday
  saturday
  both
  weekend
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      UserRole @default(customer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passes         Pass[]
  tickets        Ticket[]
  reseller       Reseller?
  clubAccounts   ClubAccount[]
  passScansDone  PassScan[]    @relation("scannedByUser")
}

model Club {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  address       String
  description   String?       @db.Text
  pictures      String[]
  instagramUrl  String?
  facebookUrl   String?
  websiteUrl    String?
  payPerVisit   Float         @default(10)
  openDays      DayOfWeek[]
  passInclusion PassInclusion @default(both)
  musicTags     String[]
  dresscodeTags String[]
  openTime      String?
  closeTime     String?
  contactEmail  String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  events       Event[]
  passScans    PassScan[]
  clubAccounts ClubAccount[]
}

model Museum {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  address      String
  description  String?  @db.Text
  pictures     String[]
  websiteUrl   String?
  payPerVisit  Float    @default(8)
  sortOrder    Int      @default(0)
  openDays     String[]
  openTime     String?
  closeTime    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passScans PassScan[]
}

model Pass {
  id               String     @id @default(cuid())
  type             PassType
  price            Float
  stripeFee        Float?     // Fee Stripe charged for this pass (from balance_transaction.fee, € not cents). Null for free / imported rows.
  userId           String
  stripePaymentId  String?
  status           PassStatus @default(purchased)
  activatedAt      DateTime?
  expiresAt        DateTime?
  refundedAt       DateTime?  // Set when status flips to refunded; used for period-accurate accounting.
  resellerId       String?
  formId           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  reseller Reseller?     @relation(fields: [resellerId], references: [id])
  form     GiveawayForm? @relation(fields: [formId], references: [id])
  scans    PassScan[]

  @@index([userId])
  @@index([resellerId])
  @@index([formId])
  @@index([status])
}

model PassScan {
  id         String   @id @default(cuid())
  passId     String
  clubId     String?
  museumId   String?
  scannedAt  DateTime @default(now())
  scannedBy  String?

  pass        Pass    @relation(fields: [passId], references: [id])
  club        Club?   @relation(fields: [clubId], references: [id])
  museum      Museum? @relation(fields: [museumId], references: [id])
  scannedUser User?   @relation("scannedByUser", fields: [scannedBy], references: [id])

  @@index([passId])
  @@index([clubId])
  @@index([museumId])
}

model Event {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?  @db.Text
  coverImage     String?
  clubId         String?
  venueName      String?
  venueAddress   String?
  date           DateTime
  isLinkedToPass Boolean  @default(false)
  isActive       Boolean  @default(true)
  salesEnded     Boolean  @default(false)
  // Optional override for the club's per-ticket retribution. When null,
  // the default formula applies (see src/lib/pricing.ts): €10 flat for
  // tickets priced ≥ €14, otherwise max(0, pricePaid − 4).
  clubTicketFee  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  club          Club?          @relation(fields: [clubId], references: [id])
  tickets       Ticket[]
  pricingPhases PricingPhase[]

  @@index([clubId])
  @@index([date])
}

model Ticket {
  id               String       @id @default(cuid())
  eventId          String
  userId           String
  stripePaymentId  String?
  stripeFee        Float?       // Fee Stripe charged for this ticket (from balance_transaction.fee, € not cents). Null for free / imported rows.
  status           TicketStatus @default(purchased)
  pricePaid        Float
  pricingPhase     PricingPhaseName
  resellerId       String?
  validatedAt      DateTime?
  refundedAt       DateTime?    // Set when status flips to refunded; used for period-accurate accounting.
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  event    Event     @relation(fields: [eventId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  reseller Reseller? @relation(fields: [resellerId], references: [id])

  @@index([eventId])
  @@index([userId])
  @@index([resellerId])
  @@index([status])
}

model PricingPhase {
  id        String           @id @default(cuid())
  eventId   String
  name      PricingPhaseName
  price     Float
  startDate DateTime
  endDate   DateTime

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
}

model Reseller {
  id                    String  @id @default(cuid())
  userId                String  @unique
  // Commission tier arrays stored as JSON. Shape:
  //   [{ upTo: number | null, rate: number }, ...]
  // upTo=null means "and above" (open-ended) and must be the last tier.
  // Match rule is non-marginal: the whole sale price uses the first
  // tier where price <= upTo. See src/lib/pricing.ts.
  passCommissionTiers   Json    @default("[{\"upTo\":null,\"rate\":0.08}]")
  ticketCommissionTiers Json    @default("[{\"upTo\":null,\"rate\":0.08}]")
  magicLinkToken        String? @unique
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  passes  Pass[]
  tickets Ticket[]
}

model GiveawayForm {
  id          String   @id @default(cuid())
  slug        String   @unique
  passType    PassType
  isActive    Boolean  @default(true)

  // Language: English (primary)
  titleEn     String
  descriptionEn String? @db.Text
  successMessageEn String? @db.Text

  // Language: French
  titleFr     String?
  descriptionFr String? @db.Text
  successMessageFr String? @db.Text

  // Language: Dutch
  titleNl     String?
  descriptionNl String? @db.Text
  successMessageNl String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  passes Pass[]
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String   @db.Text
  content     String   @db.Text
  coverImage  String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClubAccount {
  id             String  @id @default(cuid())
  clubId         String
  userId         String
  magicLinkToken String? @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([clubId])
  @@index([userId])
}
